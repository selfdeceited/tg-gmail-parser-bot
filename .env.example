TELEGRAM_BOT_TOKEN=your_token_here
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Versioned key rotation (preferred):
TOKEN_ENCRYPTION_KEY_1=<base64-encoded-32-bytes>   # generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY_CURRENT=1                     # bump to 2 when adding KEY_2, then run RotateCredentials

# Legacy single-key fallback (no rotation support):
# TOKEN_ENCRYPTION_KEY=<base64-encoded-32-bytes>

CLAUDE_API_KEY=your_api_key
